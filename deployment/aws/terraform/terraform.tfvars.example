aws_region          = "us-east-1"
environment         = "dev"
ec2_instance_type   = "r6i.2xlarge"
asg_min_size        = 1
asg_max_size        = 4
asg_desired_capacity = 2

# Cost-saving schedules (UTC)
# Stop at 1 AM UTC (~9 PM US Eastern), Start at 9 AM UTC (~5 AM US Eastern)
start_schedule = "cron(0 9 ? * MON-FRI *)"
stop_schedule  = "cron(0 1 ? * MON-FRI *)"

github_repo_url  = "https://github.com/your-username/fintech-data-platform.git"
github_branch    = "main"

kafka_replication_factor = 3
kafka_partition_count = 3
kafka_topic_name="fintech.events"

# Restrict access to platform UIs (SSH, Airflow, Spark, Grafana, etc.)
# Use your office VPN or home IP CIDR for production deployments
# admin_cidr_blocks = ["10.0.0.0/8", "203.0.113.0/24"]